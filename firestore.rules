rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to verify user is accessing their own document/subcollection
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Root user document
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Projects collection
      match /projects/{projectId} {
        allow read, write: if isOwner(userId);

        // Milestones subcollection
        match /milestones/{milestoneId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Tasks collection
      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }

      // Goals collection
      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      // Settings collection
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      // Knowledge Library collection
      match /knowledgeItems/{knowledgeItemId} {
        allow read, write: if isOwner(userId);
      }

      // Idea Vault collection
      match /ideaVault/{ideaId} {
        allow read, write: if isOwner(userId);
      }

      // Memories collection
      match /memories/{memoryId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Default deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
